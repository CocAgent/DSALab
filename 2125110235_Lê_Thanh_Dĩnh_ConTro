#include <iostream>
using namespace std;

// Cấu trúc nút
struct Node {
    int data;    // Dữ liệu
    Node* next;  // Con trỏ tới nút tiếp theo
};

int main() {
    // Tạo 3 nút
    Node* node1 = new Node;
    Node* node2 = new Node;
    Node* node3 = new Node;

    // Gán dữ liệu
    node1->data = 10;
    node2->data = 20;
    node3->data = 30;

    // Nối các nút với nhau
    node1->next = node2;
    node2->next = node3;
    node3->next = nullptr; // Cuối danh sách

    // Head là nút đầu
    Node* head = node1;

    // In danh sách
    Node* temp = head;
    while (temp != nullptr) {
        cout << temp->data << " -> ";
        temp = temp->next;
    }
    cout << "NULL" << endl;

    // Giải phóng bộ nhớ
    delete node1;
    delete node2;
    delete node3;

    return 0;
}
