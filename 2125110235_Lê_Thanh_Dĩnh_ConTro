#include <iostream>
using namespace std;

int main() {
    int a = 10;       // Khởi tạo biến a
    int* p;           // Khai báo con trỏ p

    p = &a;           // Gán địa chỉ của a cho con trỏ p

    cout << "Gia tri cua a: " << a << endl;
    cout << "Dia chi cua a: " << &a << endl;
    cout << "Gia tri con tro p (dia chi cua a): " << p << endl;
    cout << "Gia tri ma con tro p tro toi: " << *p << endl;

    // Thay đổi giá trị của a thông qua con trỏ
    *p = 20;
    cout << "Gia tri mới của a sau khi thay doi qua con tro: " << a << endl;

    return 0;
}
