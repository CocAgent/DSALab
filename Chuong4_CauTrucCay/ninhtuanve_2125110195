void KhoiTaoDS(List& l)
{
	l.pHead = l.pTail = NULL;
}
void HuyDS(List& l)
{
	Node* p;
	while (l.pHead)
	{
		p = l.pHead;
		l.pHead = l.pHead->pNext;
		p->pNext = NULL;
		delete (p);
	}
}
Node* TaoNut(int x)
{
	Node* p;
	p = new Node;
	if (p == NULL)
	{
		cout << "Khong cap phat duoc vung nho, ket thuc";
		system("pause");
		exit(1);
	}
	p->data = x;
	p->pNext = NULL;
	return p;
}
void TaoDS(List& l)
{
	int x;
	Node* p;
	do {
		cout << "\n Nhap gia tri vao DS(Nhap 0 ket thuc) : ";
		cin >> x;
		if (x == 0)
			break;
		p = TaoNut(x);
		if (l.pHead == NULL)
			l.pHead = l.pTail = p;
		else {
			l.pTail->pNext = p;
			l.pTail = p;
		}
	} while (1); //số một (1)
}
