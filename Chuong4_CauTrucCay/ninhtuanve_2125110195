bool ktnt(int x)
{
	if (x < 2)
		return false;
	for (int i = 2;i <= sqrt(x);i++)
		if (x % i == 0)
			return false;
	return true;
}
void lietkenguyento(List l)
{
	Node* p = l.pHead;
	while (p != NULL)
	{
		if (ktnt(p->data) == true)
			cout << p->data << "->";
		p = p->pNext;
	}
	cout << "NULL";
}
void lietkephantulonhondau(List l)
{
