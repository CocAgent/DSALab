}
bool ktcp(int x)
{
	if (x < 0)
		return false;
	int kq = sqrt(x);
	if (kq * kq == x)
		return true;
	else
		return false;
}
void lietkechinhphuong(List l)
{
	Node* p = l.pHead;
	while (p != NULL)
	{
		if(ktcp(p->data)==true)
			cout << p->data << "->";
		p = p->pNext;
	}
	cout << "NULL";
}
int ktratang(List l)
{
	Node* p = l.pHead;
	while (p->pNext != NULL)
	{
		if (p->data > p->pNext->data)
			return -1;
		p = p->pNext;
	}
	return 1;
}
int ktraDStanggiam(List l)
{
	Node* p = l.pHead;
	int tang;
	int giam;
	while (p->data != NULL)
	{
		if (( p->pNext->data>p->data)|| (p->pNext->data<p->data))
			giam= -1;
		else
		    tang= 1;
		p = p->pNext;
	}
	if (giam == -1)
		return -1;
	if (tang == 1)
		return 1;
	else
		return 0;
}
