using namespace std;

// Key dùng để mã hóa XOR đơn giản
const char ENCRYPT_KEY = 'K';

struct Account {
    string website;
    string username;
    string password;
};

// Cấu trúc Singly Linked List
struct ListNode {
    Account data;
    ListNode* next;
    ListNode(Account acc) : data(acc), next(nullptr) {}
};

// Cấu trúc Trie
struct TrieNode {
    TrieNode* children[128];
    bool isEndOfWord;
    Account* accountRef;

    TrieNode() {
        isEndOfWord = false;
        accountRef = nullptr;
        for (int i = 0; i < 128; i++) children[i] = nullptr;
    }
};

// Cấu trúc Stack
struct StackNode {
    string password;
    StackNode* next;
    StackNode(string pass) : password(pass), next(nullptr) {}
};

class PasswordSystem {
private:
    ListNode* headList;
    TrieNode* rootTrie;
    StackNode* topStack;

    // Hàm mã hóa/giải mã XOR
    string xorProcess(string data) {
        string output = data;
        for (int i = 0; i < data.length(); i++)
            output[i] = data[i] ^ ENCRYPT_KEY;
        return output;
    }

    void suggestRec(TrieNode* root, string currentPrefix, vector<string>& results) {
        if (root->isEndOfWord) results.push_back(currentPrefix);
        for (int i = 0; i < 128; i++) {
            if (root->children[i] != nullptr)
                suggestRec(root->children[i], currentPrefix + (char)i, results);
        }
    }

public:
    PasswordSystem() {
        headList = nullptr;
        rootTrie = new TrieNode();
        topStack = nullptr;
        srand((unsigned int)time(0));
    }

    // --- CHỨC NĂNG LƯU/ĐỌC FILE ---
    void saveToFile() {
        ofstream outFile("password_data.txt");
        ListNode* temp = headList;
        while (temp != nullptr) {
            // Mã hóa website, user, pass trước khi lưu
            outFile << xorProcess(temp->data.website) << " "
                << xorProcess(temp->data.username) << " "
                << xorProcess(temp->data.password) << endl;
            temp = temp->next;
        }
        outFile.close();
        cout << "[!] Da luu du lieu an toan vao file.\n";
    }

    void loadFromFile() {
        ifstream inFile("password_data.txt");
        if (!inFile) return;
        string w, u, p;
        while (inFile >> w >> u >> p) {
            // Giải mã sau khi đọc
            addAccount(xorProcess(w), xorProcess(u), xorProcess(p), false);
        }
        inFile.close();
        cout << "[!] Da khoi phuc du lieu tu file.\n";
    }

    // --- QUẢN LÝ TÀI KHOẢN ---
    void addAccount(string web, string user, string pass, bool showMsg = true) {
        Account newAcc = { web, user, pass };
        ListNode* newNode = new ListNode(newAcc);
        newNode->next = headList;
        headList = newNode;

        TrieNode* curr = rootTrie;
        for (char c : web) {
            int index = (int)c;
            if (curr->children[index] == nullptr) curr->children[index] = new TrieNode();
            curr = curr->children[index];
        }
        curr->isEndOfWord = true;
        curr->accountRef = &newNode->data;

        if (showMsg) cout << "[+] Da them: " << web << "\n";
    }

    // --- KIỂM TRA ĐỘ MẠNH MẬT KHẨU ---
    string evaluateStrength(string pass) {
        int score = 0;
        bool hasUpper = false, hasLower = false, hasDigit = false, hasSpecial = false;
        if (pass.length() >= 8) score += 25;
        for (char c : pass) {
            if (isupper(c)) hasUpper = true;
            if (islower(c)) hasLower = true;
            if (isdigit(c)) hasDigit = true;
            if (!isalnum(c)) hasSpecial = true;
        }
        if (hasUpper) score += 25;
        if (hasDigit) score += 25;
        if (hasSpecial) score += 25;

        if (score <= 25) return "RAT YEU (Nguy hiem!)";
        if (score <= 50) return "YEU";
        if (score <= 75) return "TRUNG BINH";
        return "MANH (An toan)";
    }

    // --- QUÉT MẬT KHẨU TRÙNG LẶP ---
    void findDuplicatePasswords() {
        cout << "--- CAC TAI KHOAN DUNG CHUNG MAT KHAU ---\n";
        bool found = false;
        ListNode* i = headList;
        while (i != nullptr) {
            ListNode* j = i->next;
            bool printedI = false;
            while (j != nullptr) {
                if (i->data.password == j->data.password) {
                    if (!printedI) {
                        cout << "\nMat khau [" << i->data.password << "] dung cho:\n";
                        cout << " -> " << i->data.website << " (" << i->data.username << ")\n";
                        printedI = true;
                    }
                    cout << " -> " << j->data.website << " (" << j->data.username << ")\n";
                    found = true;
                }
                j = j->next;
            }
            i = i->next;
        }
        if (!found) cout << "[+] Chuc mung! Khong co mat khau nao bi trung lap.\n";
    }

    // (Các hàm searchAccount, suggestWebsite, displayAll, generateRandom, undo giữ nguyên như bản trước...)
    void searchAccount(string web) {
        TrieNode* curr = rootTrie;
        for (char c : web) {
            int index = (int)c;
            if (curr->children[index] == nullptr) {
                cout << "[-] Khong tim thay: " << web << "\n";
                return;
            }
            curr = curr->children[index];
        }
        if (curr != nullptr && curr->isEndOfWord) {
            cout << "Website : " << curr->accountRef->website << "\n";
            cout << "User    : " << curr->accountRef->username << "\n";
            cout << "Pass    : " << curr->accountRef->password << "\n";
            cout << "Do manh : " << evaluateStrength(curr->accountRef->password) << "\n";
        }
    }

    void displayAllAccounts() {
        if (!headList) { cout << "[-] Rong!\n"; return; }
        cout << left << setw(15) << "Website" << setw(15) << "User" << setw(15) << "Pass" << "Do manh\n";
        ListNode* temp = headList;
        while (temp) {
            cout << left << setw(15) << temp->data.website << setw(15) << temp->data.username
                << setw(15) << temp->data.password << evaluateStrength(temp->data.password) << endl;
            temp = temp->next;
        }
    }

    void generateRandomPassword(int length) {
        string charset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*";
        string res = "";
        for (int i = 0; i < length; i++) res += charset[rand() % charset.length()];
        StackNode* newNode = new StackNode(res);
        newNode->next = topStack; topStack = newNode;
        cout << "[+] Password moi: " << res << "\n";
    }
};

void printMenu() {
    cout << "\n======= PASSWORD MANAGER PRO (ENCRYPTED) =======\n";
    cout << "1. Them tai khoan (Ma hoa & Trie)\n";
    cout << "2. Tim kiem & Danh gia do manh\n";
    cout << "3. Xem tat ca tai khoan\n";
    cout << "4. Quet mat khau trung lap (Security Scan)\n";
    cout << "5. Tao mat khau ngau nhien (Stack)\n";
    cout << "6. Luu du lieu vao file\n";
    cout << "0. Thoat (Tu dong luu)\n";
    cout << "Chon => ";
}

int main() {
    SetConsoleOutputCP(65001);
    PasswordSystem pm;
    pm.loadFromFile(); // Tu dong doc file khi mo

    int choice;
    do {
        printMenu();
        cin >> choice; cin.ignore();
        string w, u, p;
        switch (choice) {
        case 1:
            cout << "Web: "; getline(cin, w);
            cout << "User: "; getline(cin, u);
            cout << "Pass: "; getline(cin, p);
            pm.addAccount(w, u, p); break;
        case 2:
            cout << "Nhap Web can tim: "; getline(cin, w);
            pm.searchAccount(w); break;
        case 3: pm.displayAllAccounts(); break;
        case 4: pm.findDuplicatePasswords(); break;
        case 5: pm.generateRandomPassword(12); break;
        case 6: pm.saveToFile(); break;
        case 0: pm.saveToFile(); cout << "Tam biet!\n"; break;
        }
    } while (choice != 0);
    return 0;
}
